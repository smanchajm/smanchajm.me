---
/**
 * Navigation Component
 * 
 * Main site navigation with responsive behavior and theme toggle. Features centered
 * navigation on desktop and horizontal scrolling on mobile. The theme toggle is fixed
 * at the right edge with a gradient fade effect.
 * 
 * Navigation items are configured in src/config.ts. The "Home" link is removed
 * as the brand logo serves this purpose. Social links (GitHub, LinkedIn) are
 * added dynamically.
 * 
 * @component
 * 
 * @example
 * ```astro
 * <Navigation />
 * ```
 */
import { siteConfig } from '../config';
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname;

/**
 * Build navigation items from configured nav + social links.
 *
 * `siteConfig.nav` comes from an `as const` object, so we widen here
 * to support dynamically appended external links.
 */
const navItems: Array<{ label: string; href: string }> = [
  ...siteConfig.nav,
];

// Add social links if they exist
if (siteConfig.social.github) {
  navItems.push({ label: 'github', href: siteConfig.social.github });
}

if (siteConfig.social.linkedin) {
  navItems.push({ label: 'linkedin', href: siteConfig.social.linkedin });
}

/**
 * Determines if a navigation item should be marked as active
 * 
 * Checks if the current path matches the link.
 * External links (starting with http) are never active.
 * 
 * @param href - The navigation item's URL
 * @returns True if the navigation item should be marked as active
 */
const isActive = (href: string) => {
  // External links are never active
  if (href.startsWith('http')) return false;
  
  if (href === '/') {
    return currentPath === '/';
  }
  return currentPath.startsWith(href);
};
---

<nav class="site-nav" aria-label="Main navigation">
  <div class="nav-container">
    <div class="nav-brand">
      <a href="/">{siteConfig.author.name}</a>
    </div>
    <div class="nav-scroll">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li class="nav-item">
            <a 
              href={item.href} 
              class:list={['nav-link', { 'nav-link--active': isActive(item.href) }]}
              aria-current={isActive(item.href) ? 'page' : undefined}
              target={item.href.startsWith('http') ? '_blank' : undefined}
              rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
    <div class="nav-end">
      <ThemeToggle />
    </div>
  </div>
</nav>

<style>
  .site-nav {
    border-bottom: 1px solid var(--color-border);
    background: rgba(22, 22, 22, 0.8);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  /* Light mode background override */
  :global([data-theme="light"]) .site-nav {
    background: rgba(255, 255, 255, 0.8);
  }

  .nav-container {
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding: 0 1.5rem; /* Match page padding */
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  .nav-brand {
    flex-shrink: 0;
    margin-right: 2rem;
  }

  .nav-brand a {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.01em;
    font-family: monospace; /* Developer-like logo */
  }

  .nav-scroll {
    flex-grow: 1;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    /* Removed mask-image to fix the "ugly shadow" issue */
    display: flex; /* Allow flex content alignment */
  }
  
  .nav-scroll::-webkit-scrollbar {
    display: none;
  }

  .nav-list {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    white-space: nowrap;
    margin-left: auto; /* Push links to the right */
  }

  .nav-item {
    display: inline-block;
  }

  .nav-link {
    display: block;
    padding: 0.5rem 0.75rem;
    font-size: 0.9375rem;
    font-weight: 600; /* Bold/SemiBold */
    color: var(--color-text-secondary);
    text-decoration: none;
    text-transform: lowercase; /* Lowercase by default */
    border-radius: 6px;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-bg-secondary);
  }

  .nav-link--active {
    color: var(--color-text);
    background: var(--color-bg-secondary);
  }

  .nav-end {
    flex-shrink: 0;
    margin-left: 1rem;
    padding-left: 1rem;
    border-left: 1px solid var(--color-border-subtle);
  }

  @media (max-width: 768px) {
    .nav-list {
      margin-left: 0;
      justify-content: flex-start;
      gap: 1.5rem;
      padding: 0.5rem 1rem;
    }

    .nav-link {
      font-size: 0.75rem;
    }
  }
</style>

<script>
  function updateActiveNav() {
    const currentPath = window.location.pathname;
    const navLinks = document.querySelectorAll('.nav-link');
    
    navLinks.forEach((link) => {
      const href = link.getAttribute('href');
      let isActive = false;
      
      // Handle external links safely
      if (href && href.startsWith('http')) {
        isActive = false;
      } else if (href === '/') {
        isActive = currentPath === '/';
      } else if (href) {
        isActive = currentPath.startsWith(href);
      }
      
      link.classList.toggle('nav-link--active', isActive);
      if (isActive) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  }

  // Run on initial load and after each navigation
  document.addEventListener('astro:page-load', updateActiveNav);
</script>
